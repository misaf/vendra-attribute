{
	"name": "misaf/vendra-attribute",
	"description": "Reusable tenant-aware attributes and polymorphic values for Vendra models",
	"type": "vendra-module",
	"license": "MIT",
	"require": {
		"php": "^8.3",
		"filament/filament": "^5.0",
		"illuminate/support": "^13.0",
		"misaf/vendra-support": "dev-master",
		"spatie/eloquent-sortable": "^5.0",
		"spatie/laravel-package-tools": "^1.0"
	},
	"require-dev": {
		"fakerphp/faker": "^1.0",
		"larastan/larastan": "^3.0",
		"laravel/pint": "^1.0",
		"misaf/vendra-testing": "^1.0.0",
		"orchestra/testbench": "^11.0",
		"pestphp/pest": "^4.0",
		"pestphp/pest-plugin-arch": "^4.0",
		"pestphp/pest-plugin-laravel": "^4.0"
	},
	"autoload": {
		"psr-4": {
			"Misaf\\VendraAttribute\\": "src/",
			"Misaf\\VendraAttribute\\Database\\Seeders\\": "database/seeders/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Misaf\\VendraAttribute\\Database\\Factories\\": "database/factories/",
			"Misaf\\VendraAttribute\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		},
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true
	},
	"minimum-stability": "stable",
	"repositories": [
		{
			"type": "path",
			"url": "../vendra-support",
			"options": {
				"symlink": true
			}
		}
	],
	"extra": {
		"laravel": {
			"providers": [
				"Misaf\\VendraAttribute\\Providers\\AttributeServiceProvider"
			]
		}
	},
	"scripts": {
		"analyse": "vendor/bin/phpstan analyse",
		"format": "vendor/bin/pint",
		"test": "vendor/bin/pest"
	},
	"$schema": "https://getcomposer.org/schema.json"
}
